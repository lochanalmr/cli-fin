```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE specific
.vscode/
.idea/

# Build artifacts
dist/
build/
target/
```